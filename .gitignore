# ============ Python ============
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ============ Virtual envs ============
venv/
env/
.venv/
.env

# ============ IDE ============
.vscode/
.idea/
*.swp
*.swo

# ============ OS ============
.DS_Store
Thumbs.db

# ============ Large intermediate artifacts (NEVER commit media) ============
*.m4a
*.wav
*.mp4
*.mp3
*.html.gz

# ============ Whisper model cache (~500 MB, downloaded on first run) ============
*.pt
*.bin

# ============ Local secrets — do NOT commit ============
.env.local
*.local.toml
.cache/

# B 站 session cookies (hold login session — sensitive)
.bili_cookie
.bili_cookies.txt

# Streamlit local config (may contain user prefs)
.streamlit/

# IDE / tool history snapshots
.history/

# LLM config (local, may contain API key)
llm_config.json

# Scratch / temp
scratch/
tmp/

# ============ Demo shipping ============
# Ship cached transcripts so the demo works out-of-the-box
!transcripts/*.json
!transcripts/*.txt

# ============ Output (generated per run, never tracked) ============
output/